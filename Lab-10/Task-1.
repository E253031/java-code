abstract class GeometricObject {
    public abstract double getSurfaceSpace();
}

class RoundObject extends GeometricObject {
    private double r;

    public RoundObject(double r) {
        this.r = r;
    }

    @Override
    public double getSurfaceSpace() {
        return Math.acos(-1) * Math.pow(this.r, 2);
    }
}

class QuadObject extends GeometricObject {
    private double sideA;
    private double sideB;

    public QuadObject(double sideA, double sideB) {
        this.sideA = sideA;
        this.sideB = sideB;
    }

    @Override
    public double getSurfaceSpace() {
        return this.sideA * this.sideB;
    }
}

public class Main {
    public static void main(String[] args) {
        GeometricObject obj1 = new RoundObject(5.0);
        GeometricObject obj2 = new QuadObject(4.0, 6.0);

        System.out.println("Result A: " + obj1.getSurfaceSpace());
        System.out.println("Result B: " + obj2.getSurfaceSpace());
    }
}
