interface FinancialOperations {
    void cashOut(double money);
    void cashIn(double money);
    double getAvailableFunds();
}

class DutchBanglaBank implements FinancialOperations {
    private double currentBalance;

    public DutchBanglaBank(double openingBalance) {
        this.currentBalance = openingBalance;
    }

    @Override
    public void cashOut(double money) {
        if (money > 0 && money <= this.currentBalance) {
            this.currentBalance -= money;
            System.out.println("Debited: " + money + " BDT");
        } else {
            System.out.println("Transaction failed: Invalid range or insufficient balance.");
        }
    }

    @Override
    public void cashIn(double money) {
        if (money > 0) {
            this.currentBalance += money;
            System.out.println("Credited: " + money + " BDT");
        } else {
            System.out.println("Transaction failed: Amount must be positive.");
        }
    }

    @Override
    public double getAvailableFunds() {
        return this.currentBalance;
    }
}

public class Main {
    public static void main(String[] args) {
        FinancialOperations userAccount = new DutchBanglaBank(1000.0);
        
        System.out.println("Current Status: " + userAccount.getAvailableFunds());
        userAccount.cashIn(500.0);
        System.out.println("Status Updated: " + userAccount.getAvailableFunds());
        userAccount.cashOut(200.0);
        System.out.println("Status Updated: " + userAccount.getAvailableFunds());
        userAccount.cashOut(2000.0);
    }
}
