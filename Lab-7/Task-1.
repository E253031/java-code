class Calculator {
    public int add(int a, int b) {
        return a + b;
    }
    public double add(double a, double b) {
        return a + b;
    }
    public int add(int a, int b, int c) {
        return a + b + c;
    }
}
public class labrpt7 {
    public static void main(String[] args) {
        Calculator calc = new Calculator();
        System.out.println("---Calculator---");
        System.out.println("Sum of 2 integers (10 + 20): " + calc.add(10, 20));
        System.out.println("Sum of 2 double numbers (6.3 + 4.5): " + calc.add(6.3, 4.5));
        System.out.println("Sum of 3 integers (20 + 30 + 50): " + calc.add(20, 30, 50));
    }
}
