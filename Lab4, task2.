public class IdCard {

    String name;
    String id;
    String department;

    // Constructor Method
    public IdCard(String name, String id, String department) {
        this.name = name;
        this.id = id;
        this.department = department;
    }

    // Display Method
    public void displayCard() {
        System.out.println("----- ID Card -----");
        System.out.println("Name: " + name);
        System.out.println("ID: " + id);
        System.out.println("Department: " + department);
        System.out.println("-------------------");
    }

    // Main Method
    public static void main(String[] args) {

        IdCard student1 = new IdCard("Samadul Islam", "E253031", "CCE");

        student1.displayCard();
    }
}
